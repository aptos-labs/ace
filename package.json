{
  "name": "ace",
  "version": "0.0.0",
  "private": true,
  "description": "ACE monorepo",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "test": "pnpm -r test",
