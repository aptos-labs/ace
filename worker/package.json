{
  "name": "@aptos-labs/ace-worker",
  "version": "0.1.2",
  "description": "ACE Worker - key management and decryption share generation",
  "type": "module",
  "main": "dist/cli.js",
  "types": "dist/cli.d.ts",
  "bin": {
    "ace-worker": "dist/cli.js"
  },
  "files": [
    "dist/**/*"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "dev:cli": "tsx src/cli.ts",
    "start:worker0": "env $(cat local-worker-0.env | xargs) tsx src/cli.ts run-worker --port 9000",
    "start:worker1": "env $(cat local-worker-1.env | xargs) tsx src/cli.ts run-worker --port 9001",
    "start:worker-v2-0": "ACE_WORKER_V2_PRIVATE_KEY=${WORKER0_KEY} tsx src/cli.ts run-worker-v2 --port 9000 --rpc-url ${RPC_URL:-http://localhost:8080/v1} --ace-contract ${ACE_CONTRACT}",
    "start:worker-v2-1": "ACE_WORKER_V2_PRIVATE_KEY=${WORKER1_KEY} tsx src/cli.ts run-worker-v2 --port 9001 --rpc-url ${RPC_URL:-http://localhost:8080/v1} --ace-contract ${ACE_CONTRACT}",
    "start:worker-v2-2": "ACE_WORKER_V2_PRIVATE_KEY=${WORKER2_KEY} tsx src/cli.ts run-worker-v2 --port 9002 --rpc-url ${RPC_URL:-http://localhost:8080/v1} --ace-contract ${ACE_CONTRACT}",
    "start:worker-v2-3": "ACE_WORKER_V2_PRIVATE_KEY=${WORKER3_KEY} tsx src/cli.ts run-worker-v2 --port 9003 --rpc-url ${RPC_URL:-http://localhost:8080/v1} --ace-contract ${ACE_CONTRACT}",
    "lint": "eslint src/",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "ace",
    "encryption",
    "access-control"
  ],
  "license": "Apache-2.0",
  "dependencies": {
    "@aptos-labs/ace-sdk": "workspace:*",
    "@aptos-labs/ts-sdk": "^5.1.1",
    "@noble/curves": "^1.8.1",
    "@noble/hashes": "^1.7.1",
    "@solana/web3.js": "^1.98.4",
    "commander": "^11.0.0",
    "cors": "^2.8.5",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.17",
    "@types/node": "^20.0.0",
    "tsx": "^4.6.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
