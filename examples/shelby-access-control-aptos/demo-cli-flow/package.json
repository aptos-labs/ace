{
  "name": "shelby-access-control-aptos-demo-cli-flow",
  "version": "0.1.0",
  "description": "A demo CLI program for Shelby access control on Aptos",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "demo": "tsx src/demo.ts",
